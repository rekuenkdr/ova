# --- Language & Voice ---
OVA_LANGUAGE=en                                        # zh, en, ja, ko, de, fr, ru, pt, es, it
OVA_KOKORO_VOICE=af_heart                              # af_heart, af_bella, am_adam, etc.

# --- TTS Model ---
OVA_TTS_ENGINE=kokoro
OVA_KOKORO_MODEL=hexgrad/Kokoro-82M

# --- LLM ---
OVA_LLM_PROVIDER=ollama                                # ollama or openai (any OpenAI-compatible API)
OVA_CHAT_MODEL=ministral-3:3b-instruct-2512-q4_K_M
OVA_LLM_MAX_TOKENS=512                                 # Cap output length (0 = unlimited)

# --- VRAM Budget ---
OVA_ASR_GPU_MEMORY_UTILIZATION=0.4                     # GPU fraction for ASR. Increase if OOM (e.g. 0.5)

# --- Features ---
OVA_ENABLE_WAKE_WORD=true
OVA_ENABLE_TOOLS=false
OVA_TIMEZONE=Europe/Madrid
