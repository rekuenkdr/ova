# =============================================================================
# OVA Configuration
# =============================================================================
OVA_TIMEZONE=Europe/Madrid
# =============================================================================
# Server Configuration
# =============================================================================
# Backend API server (FastAPI/Uvicorn)
OVA_BACKEND_HOST=localhost
OVA_BACKEND_PORT=5173

# Frontend static file server
OVA_FRONTEND_HOST=localhost
OVA_FRONTEND_PORT=8080

# NOTE: If you change these, also update static/js/config.js

# Debug mode - enables DEBUG-level logging for all components
# Set to "true" for verbose logs from ASR, TTS, LLM, and API
OVA_DEBUG=false

# Language for TTS and chat responses
# Supported: es, en, fr, de, it, pt, ja, zh
OVA_LANGUAGE=es

# =============================================================================
# TTS Engine Selection
# =============================================================================
# qwen3 - (Default) supports voice cloning from ref_audio.wav
# kokoro - Uses predefined voices (no cloning)
OVA_TTS_ENGINE=qwen3

# =============================================================================
# Qwen3-TTS Settings (only used when OVA_TTS_ENGINE=qwen3)
# =============================================================================
# Voice profile directory under profiles/<language>/<voice> containing:
# - prompt.txt: System prompt for chat personality
# - ref_audio.wav + ref_text.txt: Voice cloning reference
#
OVA_QWEN3_VOICE=myvoice

# Uses ref_audio.wav + ref_text.txt from the voice profile for cloning
OVA_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# Streaming format (only for Qwen3 with voice cloning)
# pcm - WAV header + raw PCM chunks (lower latency, default)
# wav - Each chunk as complete WAV file (higher compatibility)
OVA_QWEN3_STREAM_FORMAT=pcm


# PCM streaming tuning parameters
# How often TTS emits audio chunks (lower = more frequent, smaller chunks)
OVA_PCM_EMIT_EVERY_FRAMES=8
# Pre-buffer threshold in samples before playback starts (9600 = 0.4s at 24kHz)
OVA_PCM_PREBUFFER_SAMPLES=9600

# Two-phase TTS streaming (aggressive first chunk for lower latency)
# First chunk uses more aggressive settings, then switches to stable settings
OVA_FIRST_CHUNK_EMIT_EVERY=5      # Emit interval for first chunk (0 to disable two-phase)
OVA_FIRST_CHUNK_DECODE_WINDOW=48  # Decode window size for first chunk phase
                                   # NOTE: If voice sounds inconsistent in first 1-2 seconds,
                                   # increase this to 64 or 72 (trades latency for consistency)
OVA_FIRST_CHUNK_FRAMES=48         # Switch to stable settings after this many frames

# =============================================================================
# Model-Specific Settings (Qwen3-TTS)
# =============================================================================
# These values depend on which TTS model you're using. Set according to table:
#
# | Setting              | 0.6B Model | 1.7B Model | Library Limit |
# |----------------------|------------|------------|---------------|
# | OVA_PCM_DECODE_WINDOW| 64         | 80         | -             |
# | OVA_MAX_TTS_FRAMES   | 1500       | 8000       | 8000          |
# | OVA_LLM_MAX_TOKENS   | 300        | 0          | -             |
#
# PCM_DECODE_WINDOW: Decode window size for phase 2 (steady-state) streaming
# MAX_TTS_FRAMES: Prevents runaway TTS generation (8000 = ~11 min at 12Hz)
# LLM_MAX_TOKENS: Limits LLM output to match TTS capacity (0 = unlimited)

OVA_PCM_DECODE_WINDOW=80
OVA_MAX_TTS_FRAMES=8000
OVA_LLM_MAX_TOKENS=0

# Streaming optimizations (torch.compile)
# Enables torch.compile for faster TTS inference
# First inference will be slow due to JIT compilation, subsequent runs are fast
# Settings are auto-selected based on OVA_QWEN3_STREAM_FORMAT:
#   - pcm: reduce-overhead mode (~1.5-1.7x speedup, optimized for low latency)
#   - wav: max-autotune + fast_codebook (~2.5-4x speedup, optimized for throughput)
OVA_ENABLE_STREAMING_OPTIMIZATIONS=true

# Codebook CUDA graph: captures codebook predictor as a single CUDA graph
# ~2x speedup on code generation, but allocates ~500MB+ additional VRAM
# Disable (default)
OVA_CODEBOOK_CUDA_GRAPH=false

# Paged attention engine: explicit paged KV cache + CUDA graphs
# Alternative to torch.compile, requires flash-attn, triton, xxhash
# Mutually exclusive with CODEBOOK_CUDA_GRAPH and torch.compile optimizations
OVA_USE_PAGED_ENGINE=false
# GPU memory fraction for paged engine KV cache (0.0-1.0)
# Higher = more KV cache blocks. 0.9 works well when TTS model is already loaded.
OVA_PAGED_GPU_MEMORY_UTILIZATION=0.9
# =============================================================================
# Early TTS Decode (LLM → TTS Interleaving)
# =============================================================================
# Start TTS before full LLM response is ready
# When enabled, TTS begins on first sentence (punctuation) or ~40 chars
# Reduces TTFB by ~200-300ms
OVA_EARLY_TTS_DECODE=true

# =============================================================================
# Barge-In (Voice Activity Detection)
# =============================================================================
# Enable barge-in: user can interrupt TTS playback by speaking
# Uses client-side Silero VAD (neural) with browser echo cancellation
# Falls back to RMS energy if Silero model fails to load
OVA_ENABLE_BARGE_IN=true

# VAD sensitivity (Silero speech probability threshold, 0.0-1.0)
# Lower = more sensitive (may trigger on background noise)
# Higher = less sensitive (may miss quiet speech)
# Note: falls back to RMS energy (~0.015) if Silero model fails to load
OVA_VAD_THRESHOLD=0.5

# Auto-send timing (barge-in recording phase)
OVA_AUTO_SEND_SILENCE_MS=1200    # Silence duration to trigger auto-send (ms)
OVA_AUTO_SEND_CONFIRM_MS=128    # Speech confirmation for auto-send (ms, ~4 Silero frames)

OVA_AUTO_SEND_TIMEOUT_MS=3000   # Cancel recording if no speech detected (ms)

# Barge-in cooldown: suppress barge-in for N ms after auto-send fires
# Prevents false-positive barge-in loops (auto-send → response → barge-in → repeat)
OVA_BARGE_IN_COOLDOWN_MS=1200

# VAD confirm frames: consecutive Silero frames (~32ms each) needed to confirm speech
# Higher = less likely to trigger on coughs/noise, but slightly slower detection
OVA_VAD_CONFIRM_FRAMES=2

# Barge-in grace period: delay VAD activation after playback starts (ms)
# Prevents early TTS audio from leaking through echo cancellation and triggering false barge-in
OVA_BARGE_IN_GRACE_MS=500

# Backchannel filter: discard filler words (yeah, ok, mmm, etc.) during barge-in
# Set to false to send all barge-in transcripts to the LLM, even short fillers
OVA_BACKCHANNEL_FILTER=false

# Maximum pause duration for [pause:X] prosody tags (seconds)
# Tags requesting longer pauses are clamped to this value
OVA_MAX_PAUSE_DURATION=3.0

# =============================================================================
# Wake Word Detection
# =============================================================================
# Enable always-on wake word listening when idle
# Requires OVA_ENABLE_BARGE_IN to be enabled (uses same VAD + mic infrastructure)
# Mic permission is requested eagerly on page load when enabled
OVA_ENABLE_WAKE_WORD=false

# Wake word phrase (use real English words for reliable ASR recognition)
OVA_WAKE_WORD="hey nova"

# =============================================================================
# Kokoro TTS Settings (only used when OVA_TTS_ENGINE=kokoro)
# =============================================================================
# Kokoro ignores ref_audio.wav - uses predefined voices instead
OVA_KOKORO_MODEL=hexgrad/Kokoro-82M

# Kokoro voice presets (see https://github.com/hexgrad/kokoro)
# English: af_heart, af_bella, af_nicole, af_sarah, af_sky, am_adam, am_michael
# For other languages, voice selection may be limited
OVA_KOKORO_VOICE=af_heart

# =============================================================================
# LLM Provider
# =============================================================================
# Which LLM backend to use:
#   ollama  - (Default) Local Ollama server
#   openai  - Any OpenAI-compatible server (TensorRT-LLM, vLLM, etc.)
# Switching provider requires restart.
OVA_LLM_PROVIDER=ollama

# Chat model name (used by both providers)
OVA_CHAT_MODEL=ministral-3:3b-instruct-2512-q4_K_M

# OpenAI-compatible provider settings (only used when OVA_LLM_PROVIDER=openai)
# Base URL for the OpenAI-compatible API server
OVA_LLM_BASE_URL=http://localhost:8000/v1
# API key (use "not-needed" for local servers without auth)
OVA_LLM_API_KEY=not-needed

# =============================================================================
# ASR (Speech Recognition) Settings - Embedded in Backend
# =============================================================================
# Qwen3-ASR model - runs embedded in the backend (no separate server)
OVA_ASR_MODEL=Qwen/Qwen3-ASR-0.6B

# GPU memory utilization for ASR (0.0-1.0)
OVA_ASR_GPU_MEMORY_UTILIZATION=0.4

# Max sequence length for ASR model
OVA_ASR_MAX_MODEL_LEN=2048

# Streaming ASR settings
OVA_ASR_CHUNK_SIZE_SEC=0.5          # Audio chunk duration (0.4-0.8s; larger = better accuracy)
OVA_ASR_UNFIXED_CHUNK_NUM=4         # First N chunks use no prior context (bootstrap phase)
OVA_ASR_UNFIXED_TOKEN_NUM=5         # Rollback N tokens at chunk boundaries for stability

# =============================================================================
# HuggingFace Settings
# =============================================================================
# Suppress HuggingFace network calls (use cached models only)
# Set to 0 for first-time install to allow model downloads
HF_HUB_OFFLINE=0

# =============================================================================
# Security Settings
# =============================================================================
# Input size limits (0 = disabled, values in bytes/characters)
# These protect against denial-of-service via oversized payloads
OVA_MAX_TEXT_LENGTH=4096           # characters (max user input per request)
OVA_MAX_IMAGE_SIZE=20971520        # bytes (20MB)
OVA_MAX_AUDIO_SIZE=20971520        # bytes (20MB)

# Allowed values whitelist (comma-separated)
# These define which values are ACCEPTED by the /v1/settings API endpoint.
# Only modify if you add a new TTS engine or need to restrict options.
# Removing values here will reject those settings at runtime.
OVA_SUPPORTED_TTS_ENGINES=qwen3,kokoro                      # Valid: qwen3, kokoro
OVA_SUPPORTED_LANGUAGES=es,en,fr,de,it,pt,ja,zh,ko,ru,hi    # Valid: es,en,fr,de,it,pt,ja,zh,ko,ru,hi
OVA_SUPPORTED_STREAM_FORMATS=pcm,wav                        # Valid: pcm, wav

# Disable /v1/restart endpoint (recommended for production - DoS risk)
OVA_DISABLE_RESTART_ENDPOINT=false

# Disable frontend settings panel (hides settings button, blocks POST /v1/settings)
OVA_DISABLE_FRONTEND_SETTINGS=false

# Disable multimodal input (removes text/image input section, blocks /v1/chat)
OVA_DISABLE_MULTIMODAL=false

# Disable frontend (API-only mode for SDK usage)
# When true, only the backend starts. No static file server on port 8080.
OVA_DISABLE_FRONTEND_ACCESS=false

# API key authentication (leave empty or remove to disable)
# When set, all requests must include "Authorization: Bearer <key>" header.
OVA_API_KEY=

# =============================================================================
# MCP (Model Context Protocol) Client
# =============================================================================
# Connect to external MCP servers for additional tool capabilities
# Configure servers in mcp_servers.json (same format as Claude Desktop / VS Code)
OVA_ENABLE_MCP=false

# Path to MCP server config file (relative to project root or absolute)
OVA_MCP_CONFIG=mcp_servers.json

# Per-server connection timeout (seconds)
OVA_MCP_CONNECT_TIMEOUT=10

# Per-tool call timeout (seconds)
OVA_MCP_TOOL_TIMEOUT=30

# =============================================================================
# Tool/Function Calling
# =============================================================================
# Master toggle: enable LLM tool/function calling (get time, set timers, etc.)
# When enabled, the LLM can invoke registered tools and incorporate results
# into spoken responses. Adds ~200ms latency only when tools are actually called.
OVA_ENABLE_TOOLS=false

# Maximum tool-call round-trips per request (prevents runaway loops)
OVA_MAX_TOOL_ITERATIONS=5

# Comma-separated list of tool function names to disable
# Example: OVA_DISABLED_TOOLS=web_search,set_timer
OVA_DISABLED_TOOLS=

# Per-tool overrides (uncomment to enable/disable individual tools)
# OVA_TOOL_GET_CURRENT_DATETIME_ENABLED=true
# OVA_TOOL_SET_TIMER_ENABLED=true
# OVA_TOOL_CHECK_TIMERS_ENABLED=true
# OVA_TOOL_WEB_SEARCH_ENABLED=true

# API key for web search tool (tool is disabled by default; enable via override)
# OVA_SEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Network Exposure Notes
# -----------------------------------------------------------------------------
# OVA is designed for localhost use. For network/internet exposure, consider:
#
# 1. API Authentication:
#    Set OVA_API_KEY above.
#
# 2. Rate Limiting (not implemented - use slowapi or nginx if needed):
#    # pip install slowapi
#    # See: https://github.com/laurentS/slowapi
#
# 3. HTTPS/TLS (use a reverse proxy):
#    # nginx, caddy, or traefik recommended for TLS termination
#    # Never expose OVA directly to the internet without TLS
#
# 4. Firewall: Restrict access to trusted IPs if possible
#
# 5. Production Feature Flags:
#    OVA_DISABLE_RESTART_ENDPOINT=true   # Prevents DoS via /v1/restart endpoint
#    OVA_DISABLE_FRONTEND_SETTINGS=true  # Locks settings, removes UI button
#    OVA_DISABLE_MULTIMODAL=true         # Voice-only mode, removes text/image input
#    OVA_DISABLE_FRONTEND_ACCESS=true    # API-only mode, no static file server
